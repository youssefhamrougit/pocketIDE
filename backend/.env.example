# ============================================================
# PocketIDE Backend — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================
#
# ██████╗ ██████╗ ██████╗ ██╗   ██╗██╗██████╗ ███████╗
# ╚════██╗╚════██╗╚════██╗██║   ██║██║██╔══██╗██╔════╝
#  █████╔╝ █████╔╝ █████╔╝██║   ██║██║██║  ██║█████╗
#  ╚═══██╗ ╚═══██╗ ╚═══██╗╚██╗ ██╔╝██║██║  ██║██╔══╝
# ██████╔╝██████╔╝██████╔╝ ╚████╔╝ ██║██████╔╝███████╗
# ╚═════╝ ╚═════╝ ╚═════╝   ╚═══╝  ╚═╝╚═════╝ ╚══════╝
#
# ============================================================

# ─── Server ──────────────────────────────────────────────────

# Port the API server listens on
# Default: 3001
PORT=3001

# Host address to bind to
# Use 0.0.0.0 to accept connections from any network interface
# Use 127.0.0.1 to accept connections from localhost only
# Default: 0.0.0.0
HOST=0.0.0.0

# Environment mode
# Options: development | production
# Development enables verbose logging (morgan dev) and relaxed CSP
# Default: development
NODE_ENV=development

# ─── JWT Authentication ─────────────────────────────────────

# Secret key used to sign and verify JWT tokens
# ⚠️ IMPORTANT: Change this to a strong, unique value in production!
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-key-change-me-in-production

# JWT token expiration time
# Uses the `ms` format: 7d, 24h, 60m, 3600s
# Default: 7d
JWT_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────────

# Allowed CORS origin(s)
# Set to your Flutter app's URL in production, e.g. https://app.pocketide.dev
# Use * to allow any origin (development only)
# Default: *
CORS_ORIGIN=*

# ─── Limits ──────────────────────────────────────────────────

# Maximum file upload size in bytes
# Default: 5242880 (5MB)
MAX_FILE_SIZE=5242880

# Bcrypt salt rounds for password hashing
# Higher = more secure but slower. 10-12 is a good range.
# Default: 10
BCRYPT_SALT_ROUNDS=10

# ─── Storage Paths (optional overrides) ──────────────────────
# By default, data is stored in backend/data/
# Only set these if you need custom paths

# DATA_DIR=./data
# PROJECTS_DIR=./data/projects
